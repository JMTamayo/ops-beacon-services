# Required for the LLM
LLM_API_KEY=
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.2

# ener-vault (Docker network hostname)
ENER_VAULT_BASE_URL=http://ener-vault:8080

# Optional: Power Automate → Teams (canal del equipo de operación). URL completa; secreto.
# TEAMS_WEBHOOK_URL=

# API auth (bcrypt hash of the plain key; same pattern as https://github.com/JMTamayo/aura )
SERVER_API_KEY_NAME=X-API-Key
SERVER_API_KEY_VALUE_HASHED='REPLACE_WITH_bcrypt_hash'

# Optional: RFC 7807 Problem Details "type" URI prefix (default: https://ops-beacon.invalid/problems)
# PROBLEM_TYPE_URI_PREFIX=https://example.com/problems
